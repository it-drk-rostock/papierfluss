model Team {
  id                   String     @id @default(uuid())
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  name                 String
  contactEmail         String?
  users                User[]
  forms                Form[]
  formsV2              FormV2[]
  responsibleForms     Form[]     @relation("ResponsibleTeam")
  responsibleFormsV2   FormV2[]   @relation("ResponsibleTeamV2")
  responsibleProcesses Process[]  @relation("ResponsibleTeam")
  responsibleWorkflows Workflow[] @relation("ResponsibleTeam")
  processes            Process[]
  workflows            Workflow[]

  @@unique([name])
}
